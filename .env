# Postgres
POSTGRES_USER=crypto
POSTGRES_PASSWORD=crypto_secret
POSTGRES_DB=crypto_db

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Binance (no key needed for public streams)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# CoinGecko (free tier, no key needed)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Reddit (get from reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=crypto-pipeline/1.0

# Slack (optional, for Airflow alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Symbols to track (comma-separated)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
